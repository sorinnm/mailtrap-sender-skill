# Copy to `.env` and fill in. `.env` is gitignored — never commit real tokens.

# Mailtrap API token (Bearer auth). Required.
MAILTRAP_API_TOKEN=

# sandbox = mail goes to a Mailtrap test inbox (safe, default)
# live    = real delivery to actual recipients (requires verified domain)
MAILTRAP_MODE=sandbox

# Required when MAILTRAP_MODE=sandbox. Found in your Mailtrap inbox URL/settings.
MAILTRAP_INBOX_ID=

# Default sender used when the recipients JSON omits `from`.
MAILTRAP_FROM_EMAIL=
MAILTRAP_FROM_NAME=

# Default Mailtrap category, sent as the `X-MT-Category` header when the
# recipients JSON omits `category`. Optional.
MAILTRAP_CATEGORY=
